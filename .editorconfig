root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cs,csx}]
indent_size = 4

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# --- EF Core auto-generated migrations (all auto-generated, don't lint) ---
[**/Data/Migrations/*.cs]
dotnet_analyzer_diagnostic.category-Design.severity = none
dotnet_analyzer_diagnostic.category-Style.severity = none
dotnet_analyzer_diagnostic.category-Usage.severity = none
dotnet_analyzer_diagnostic.category-Performance.severity = none
generated_code = true

# --- Roslyn analyzer rules ---
[*.{cs,csx}]

# Roslyn: suppress noise, keep what catches real bugs
dotnet_diagnostic.CA1305.severity = none        # IFormatProvider — no i18n needed
dotnet_diagnostic.CA1816.severity = none        # GC.SuppressFinalize — no finalizers in this project
dotnet_diagnostic.CA1822.severity = none        # Make static — primary ctor params look like instance members
dotnet_diagnostic.CA1848.severity = none        # LoggerMessage delegates — overkill for TUI app
dotnet_diagnostic.CA1859.severity = none        # Concrete type for perf — marginal, not worth interface churn
dotnet_diagnostic.CA1873.severity = none        # Log argument cost — low-throughput app

# Culture-sensitive ToString — TUI displays local data only, no i18n
dotnet_diagnostic.MA0011.severity = none
dotnet_diagnostic.MA0075.severity = none
dotnet_diagnostic.MA0076.severity = none

# Terminal.Gui patterns that can't be avoided
dotnet_diagnostic.MA0056.severity = suggestion  # Overridable members in ctor — Dialog.Add() requires this
dotnet_diagnostic.MA0134.severity = suggestion  # Observe async result — fire-and-forget intentional in UI
dotnet_diagnostic.MA0008.severity = none        # StructLayoutAttribute — not needed for our record structs

# Meziantou: keep rules that catch real bugs
dotnet_diagnostic.MA0002.severity = suggestion
dotnet_diagnostic.MA0004.severity = suggestion
dotnet_diagnostic.MA0006.severity = suggestion
dotnet_diagnostic.MA0009.severity = warning    # Regex DoS — real security issue
dotnet_diagnostic.MA0016.severity = suggestion
dotnet_diagnostic.MA0038.severity = none       # Deprecated, replaced by CA1822
dotnet_diagnostic.MA0048.severity = suggestion
dotnet_diagnostic.MA0051.severity = suggestion
